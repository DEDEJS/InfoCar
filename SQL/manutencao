CREATE TABLE `infocar`.`maintenance` (`id_manutencao` INT(10) NOT NULL AUTO_INCREMENT , `peca` VARCHAR(50) CHARACTER SET utf8 COLLATE utf8_general_ci NOT NULL , `valor_peca` INT(10) NOT NULL , `valor_mao_de_obra` VARCHAR(10) CHARACTER SET utf8 COLLATE utf8_general_ci NOT NULL , `data` DATE NOT NULL , `tipo_de_manutencao` VARCHAR(50) CHARACTER SET utf8 COLLATE utf8_general_ci NOT NULL , `local` VARCHAR(50) CHARACTER SET utf8 COLLATE utf8_general_ci NOT NULL , PRIMARY KEY (`id_manutencao`)) ENGINE = InnoDB;
